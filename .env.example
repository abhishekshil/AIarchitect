# =============================================================================
# AI Solution Planning Engine — local environment template
# Copy to .env for docker compose variable interpolation.
# Never commit real secrets in .env files.
# =============================================================================

# --- Infrastructure credentials (docker compose) ---
POSTGRES_USER=aspe
POSTGRES_PASSWORD=aspe_dev_change_me
POSTGRES_DB=aspe
POSTGRES_PORT=5432
REDIS_HOST_PORT=6379

# --- Exposed host ports ---
API_HOST_PORT=8000
WEB_PORT=3000

# --- API runtime values for dockerized backend ---
API_APP_NAME=AI Solution Planning API
API_APP_ENV=docker
API_DEBUG=true
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_DATABASE_URL=postgresql+asyncpg://aspe:aspe_dev_change_me@postgres:5432/aspe
API_REDIS_URL=redis://redis:6379/0
PUBLIC_API_BASE_URL=http://localhost:8000

# --- JWT ---
# Replace with a long random value for any shared environment.
JWT_SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
LLM_ENABLED=false
LLM_PROVIDER=disabled
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_TIMEOUT_S=12
LLM_MAX_RETRIES=1

# --- Frontend runtime values ---
NEXT_PUBLIC_API_URL=http://localhost:8000
WATCHPACK_POLLING=true
# =============================================================================
# AI Solution Planning Engine — root environment template
# Copy to .env only for tooling that reads from repo root; prefer per-app files.
# =============================================================================

# --- Shared infrastructure (used by docker-compose and local services) ---
POSTGRES_USER=aspe
POSTGRES_PASSWORD=aspe_dev_change_me
POSTGRES_DB=aspe
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6379

# --- Object storage (S3-compatible; optional in Phase 1) ---
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY_ID=minio
# S3_SECRET_ACCESS_KEY=minio_dev_change_me
# S3_BUCKET_NAME=aspe-artifacts
# S3_REGION=us-east-1

# --- API ↔ Web (CORS / public URL) ---
API_PUBLIC_URL=http://localhost:8000
WEB_PUBLIC_URL=http://localhost:3000
