# API service (apps/api) — copy to .env

APP_NAME=AI Solution Planning API
APP_ENV=local
DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated origins for CORS (no spaces)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Infrastructure for host-run API (dockerized DB/Redis on localhost ports)
DATABASE_URL=postgresql+asyncpg://aspe:aspe_dev_change_me@localhost:5432/aspe
REDIS_URL=redis://localhost:6379/0

# Snippet generation base URL shown in generated examples
PUBLIC_API_BASE_URL=http://localhost:8000

# JWT — replace in non-local environments
JWT_SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM integration (optional; deterministic fallback remains active when disabled)
LLM_ENABLED=true
LLM_PROVIDER=openai_compatible
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_TIMEOUT_S=12
LLM_MAX_RETRIES=3
